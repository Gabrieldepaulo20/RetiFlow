# ═══════════════════════════════════════════════════════════════════════════════
# VARIÁVEIS DE AMBIENTE — RETIFLOW
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite .env.local — ele está no .gitignore.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Auth ──────────────────────────────────────────────────────────────────────
# 'mock'  → login de demonstração local (senha: demo123), sem backend
# 'real'  → autenticação via Supabase Auth
VITE_AUTH_MODE=mock

# ── Supabase ──────────────────────────────────────────────────────────────────
# A anon key É segura no frontend — é uma chave pública por design.
# A service_role key NUNCA deve ficar no frontend.
# Encontre em: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ── API externa (opcional) ────────────────────────────────────────────────────
# URL base se usar um backend próprio no futuro
# VITE_API_URL=https://api.seudominio.com.br
