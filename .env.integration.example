# Credenciais do ambiente Supabase de TESTE.
# Copie para .env.integration e preencha com valores reais.
# NUNCA comite .env.integration — está no .gitignore.
#
# Pode apontar para:
#   - Supabase Branch criado pelo dashboard (recomendado)
#   - Projeto Supabase separado para testes
#   - Mesmo projeto de prod com usuário de teste isolado (atual)
#
# Obter service_role: dashboard.supabase.com → projeto → Settings → API

VITE_SUPABASE_URL=https://dqeoxxokvvcpssajycgq.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>
VITE_SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Usuário dedicado para testes — criado automaticamente por beforeAll.
# Use um e-mail que nunca será usado em produção.
TEST_USER_EMAIL=integration.test@retifica.com
TEST_USER_PASSWORD=<senha-forte-para-usuario-de-teste>
